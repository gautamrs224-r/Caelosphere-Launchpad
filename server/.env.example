PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (Stage 4). Leave blank to run the API
# without a database — routes that touch the DB will simply error until set.
MONGO_URI=

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Frontend origin allowed by CORS
CLIENT_URL=http://localhost:5173

# Gemini API key (Stage 6 — not used yet)
GEMINI_API_KEY=
